  "safety_features": [
    "All Mohawk lifts must be installed on concrete only",
    "Never install on hand mixed concrete",
    "Never install on expansion seams or cracked/defective concrete",
    "Do not install on secondary floor level or ground floor with basement without written authorization from building architect and Mohawk approval",
