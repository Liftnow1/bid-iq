# Copy to .env.local and fill in real values. .env.local is gitignored.

# Postgres / Neon — used by all DB code paths.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Anthropic API key — used by /api/ask and the bidiq ingester.
ANTHROPIC_API_KEY=sk-ant-...

# MCP server bearer token — guards /api/mcp. Generate with:
#   openssl rand -hex 32
# Same value must also be set in Vercel project env vars (Production +
# Preview), then redeploy. See BIDIQ-MCP.md.
BIDIQ_MCP_TOKEN=replace-with-output-of-openssl-rand-hex-32

# Optional retrieval tuning knobs. Defaults are sensible; uncomment to
# override.
# FULL_CONTENT_TOP_N=5            # /api/ask: candidates that get full raw_content
# SOURCE_TYPE_PDF_BOOST=1.5       # /api/ask: ts_rank multiplier for ingested_pdf rows

# Sort-report exclusion list (pipe-delimited). Used by
# scripts/sort_report/run_sort_report.py to quarantine PII/personal files
# before they reach the classifier. Real values live in .env.local only.
BIDIQ_EXCLUSION_STRINGS=string1|string2|string3
